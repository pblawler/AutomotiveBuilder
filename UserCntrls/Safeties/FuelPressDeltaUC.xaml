<UserControl x:Class="AutomotiveBuilder.UserCntrls.Safeties.FuelPressDeltaUC"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:oxy="http://oxyplot.org/wpf"             
        mc:Ignorable="d" Background="White">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="507"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="5*"/>
            <RowDefinition Height="5*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="1" BorderThickness="2" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" BorderBrush="Black" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Tires/Wheels" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Wheel Diameter:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <ComboBox Width="100" Height="22" Margin="1" ItemsSource="{Binding WheelDiameters, Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                              SelectedItem="{Binding DriveTrainData.WheelDiameter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Tire Width (mm):" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.TireWidth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                             HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Tire Profile (%):" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.TireAspectRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                             HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Tire Diameter (inches):" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBlock Width="100" Height="12" Margin="1" Text="{Binding DriveTrainData.TireDiameterInches, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat=F2}"
                             HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" BorderThickness="2" HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" BorderBrush="Black" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Trans/Diff" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Number of Gears:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <ComboBox Width="100" Height="22" Margin="1" ItemsSource="{Binding NoGears, Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                      SelectedItem="{Binding DriveTrainData.NumberOfGears, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Diff. Ratio:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.DiffRatio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                     HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="VSS per Rev:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.VSSPerRev, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                     HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="WOT Shift RPM:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.WOTrpm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                     HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="5" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Rev. Limit RPM:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.MaxRPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                        HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="0" Grid.Column="2" Grid.ColumnSpan="1" BorderThickness="2" HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" BorderBrush="Black" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Shift" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Gain:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.Gain, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                     HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="2" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Decay:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.Decay, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                     HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="3" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Shift RPM:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.ShiftRPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                     HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="4" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Min. Shift RPM:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.MinRPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                        HorizontalContentAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Grid.Row="5" HorizontalAlignment="Right" Margin="1,1,10,1">
                    <TextBlock Text="Table Size:" FontSize="14" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                    <TextBox Width="100" Height="22" Margin="1" Text="{Binding DriveTrainData.TableSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}"
                        HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
        <Border Grid.Row="0" Grid.Column="3" Grid.ColumnSpan="1" BorderThickness="2" HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch" BorderBrush="Black" Margin="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="Gears" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="10"/>
                <DataGrid Grid.Row="1" ItemsSource="{Binding DriveTrainData.Gears}" AutoGenerateColumns="False" CanUserAddRows="False" RowHeight="20">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Gear Number" Binding="{Binding GearNumber}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Ratio" Binding="{Binding Ratio, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}" IsReadOnly="False"/>
                        <DataGridTextColumn Header="Min. Speed" Binding="{Binding MinSpeed}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Cruise Speed" Width="auto" Binding="{Binding CruiseSpeed}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="WOT Shift Speed" Width="100" Binding="{Binding MaxShiftSpeed}" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Max Speed" Width="auto" Binding="{Binding MaxSpeed}" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
        <TabControl Grid.Row="1" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="5">
            <TabItem Header="Shift Schedule">
                <Border BorderThickness="2" HorizontalAlignment="Stretch">
                    <DataGrid ItemsSource="{Binding DriveTrainData.ShiftSchedules}" 
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeight="60">
                        <DataGrid.Columns>
                            <DataGridTemplateColumn Header="Schedule" IsReadOnly="True" Width="80">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding ScheduleName}" FontWeight="Bold" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Throttle" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Text="RPM" FontSize="10" HorizontalAlignment="Center"/>
                                            <TextBlock Text="MPH" FontSize="10" HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTemplateColumn Header="Shift Points" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding ShiftPoints}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="Gray" BorderThickness="1" Margin="1" Padding="1">
                                                            <StackPanel Orientation="Vertical" Width="65">
                                                                <TextBlock Text="{Binding ThrottlePosition, StringFormat={}{0}%}" 
                                                                       HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Rpm}" 
                                                                       FontSize="12" HorizontalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Mph}" 
                                                                       FontSize="12" HorizontalAlignment="Center"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>
            </TabItem>
            <TabItem Header="TCC Lock/Unlock">
                <Border>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Orientation="Vertical" Grid.Row="0" HorizontalAlignment="Left" Margin="10">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <TextBlock Text="Minimum Gear for TCC:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="1,0,5,0"/>
                                <ComboBox Width="100" Height="22" ItemsSource="{Binding DriveTrainData.AvailableGears, Mode=OneWay,UpdateSourceTrigger=PropertyChanged}" 
                                    SelectedItem="{Binding DriveTrainData.MinTCCgear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}" HorizontalContentAlignment="Center" Margin="1,0,5,0"/>
                                <TextBlock Text="Triple Disk TCC:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="1,0,5,0"/>
                                <ComboBox Width="100" Height="22" SelectedItem="{Binding DriveTrainData.TDCC, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}"
                                  ItemsSource="{Binding DriveTrainData.YN, Mode=OneWay}" HorizontalContentAlignment="Center" Margin="1,0,5,0"/>
                                <TextBlock Text="Stall RPM:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="5,0,5,0"/>
                                <TextBox Text="{Binding DriveTrainData.StallSpeed, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}" FontSize="16" FontWeight="Normal" HorizontalAlignment="Center" Margin="5,0,5,0" MinWidth="80" HorizontalContentAlignment="Center"/>
                                <TextBlock Text="Max Cruise Throttle:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="1,0,5,0"/>
                                <ComboBox Width="100" Height="22" SelectedItem="{Binding DriveTrainData.MaxCruiseThrottle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}" 
                              ItemsSource="{Binding DriveTrainData.MCT}"
                              HorizontalContentAlignment="Center" Margin="1,0,5,0"/>
                                <TextBlock Text="WOT Transition Throttle:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="1,0,5,0"/>
                                <ComboBox Width="100" Height="22" SelectedItem="{Binding DriveTrainData.WOTtransitionThrottle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}" 
                              ItemsSource="{Binding DriveTrainData.WTT}"
                              HorizontalContentAlignment="Center" Margin="1,0,5,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,15,0,3">
                                <TextBlock Text="WOT Lock RPM:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="5,0,5,0"/>
                                <TextBox Text="{Binding DriveTrainData.WOTlockRPM, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1500}" FontSize="16" FontWeight="Normal" HorizontalAlignment="Center" Margin="5,0,5,0" MinWidth="80" HorizontalContentAlignment="Center"/>
                                <TextBlock Text="Max WOT Gear:" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" Margin="1,0,5,0"/>
                                <ComboBox Width="100" Height="22" SelectedItem="{Binding DriveTrainData.WOTmaxGear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}" 
                              ItemsSource="{Binding DriveTrainData.AvailableGears, Mode=OneWay,UpdateSourceTrigger=PropertyChanged}"
                              HorizontalContentAlignment="Center" Margin="1,0,5,0"/>
                            </StackPanel>
                        </StackPanel>
                        <oxy:PlotView Model="{Binding TCCplotModel}" Grid.Row="1" Margin="3,1,3,10"/>
                        <!--<DataGrid Grid.Row="1" ItemsSource="{Binding DriveTrainData.ShiftSchedules}" Margin="3,1,3,10"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  RowHeight="60">
