<Window x:Class="AutomotiveBuilder.Views.PartUtils.SelectPartView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutomotiveBuilder.Views.PartUtils"
        mc:Ignorable="d"
        Title="Select Part" Height="800" Width="800"
        WindowState="Normal" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" ShowInTaskbar="False"
        DataContext="{Binding PartSelectViewModel, Source={StaticResource Locator}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Vender" FontWeight="Bold" Margin="0,0,0,5"/>
                <ComboBox HorizontalAlignment="Left" Height="23" Margin="0,0,0,0" VerticalAlignment="Top" Width="202"
                      ItemsSource="{Binding MyVenderList}" DisplayMemberPath="Name"
                      SelectedValue="{Binding SelectedVender, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Catagory" HorizontalAlignment="Left" Margin="10,0,0,5" VerticalAlignment="Top" Width="139" 
                           FontWeight="Bold"        />
                <ComboBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                      ItemsSource="{Binding PartCatagories}" DisplayMemberPath="Name" SelectedValuePath="ID"
                                      SelectedValue="{Binding CatagoryID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            <StackPanel Orientation="Vertical">
                <TextBlock Text="Sub-Catagory" HorizontalAlignment="Left" Margin="10,0,0,5" VerticalAlignment="Top" Width="139" FontWeight="Bold"/>
                <ComboBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                    ItemsSource="{Binding PartSubCatagories}" DisplayMemberPath="Name" SelectedValuePath="ID"
                                    SelectedValue="{Binding SubCatagoryID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </StackPanel>
        <Border Grid.Row="1" Margin="10" BorderBrush="Gray" BorderThickness="1">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <StackPanel Orientation="Vertical">
                            <Label Content="Name" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                      Text="{Binding SelectedPart.Name, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="Part Number" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                  Text="{Binding SelectedPart.PartNumber, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="URL" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left" 
                                           MouseUp="Label_MouseUp" Style="{StaticResource Hyperlink}"/>
                            <TextBox x:Name="PartURL" HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" MinWidth="325"
                                      Text="{Binding SelectedPart.URL, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True"/>
                        </StackPanel>
                    </StackPanel>
                    <Border BorderThickness="2" AllowDrop="True" Background="Transparent">
                        <Image x:Name="PartImg"  HorizontalAlignment="Center" VerticalAlignment="Top" Stretch="Fill" Margin="2,2,2,2" Height="250" Width="250"
                               Source="{Binding SelectedPart.ImgHEX, Converter={StaticResource HexToImageConverter}, Mode=OneWay, UpdateSourceTrigger=PropertyChanged}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
        
        <DataGrid Grid.Row="2" Margin="10" AutoGenerateColumns="False" ItemsSource="{Binding TableParts}" SelectionMode="Single" CanUserAddRows="False"
                  SelectedItem="{Binding SelectedPart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Part Number" Binding="{Binding PartNumber}" Width="*"/>
                <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="2*"/>
                <DataGridTextColumn Header="Price" Binding="{Binding Cost, StringFormat=C}" Width="*"/>
                <DataGridTextColumn Header="Stock" Binding="{Binding QuantityOnHand}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="OK" Width="75" Margin="5" IsDefault="True" Click="Button_Click"/>
            <Button Content="Cancel" Width="75" Margin="5" IsCancel="True" Click="Button_Click_1"  />
        </StackPanel>
    </Grid>
</Window>
