<Window x:Class="AutomotiveBuilder.Views.HPandETcalculatorView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutomotiveBuilder.Views"
        mc:Ignorable="d"
        Title="Horse Power and Elapse Time Calculations" Height="675" Width="900"
        DataContext="{Binding Main, Source={StaticResource Locator}}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5*" />
            <ColumnDefinition Width="5*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="45*"/>
            <RowDefinition Height="55*"/>
        </Grid.RowDefinitions>
            <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="1" BorderBrush="Black" BorderThickness="1" Margin="1">
                <StackPanel>
                    <Label Content="Elapse Time Estimator" HorizontalAlignment="Center"
                   Margin="5" FontWeight="Bold" FontSize="14"/>
                    <Label Content="Wheel Horse Power" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="whp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calcWHP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}"/>
                    <Label Content="Vehicle Weight (lbs)" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBox x:Name="vw" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calcVehicalWght, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/4 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="eet" Width="auto" Margin="0,5,0,5" HorizontalAlignment="Center"
                       Text="{Binding calc14et, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/4 mile trap speed (mph):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="qmph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc14mph, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/8 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="eeet" Width="auto" Margin="0,5,0,5" HorizontalAlignment="Center"
                       Text="{Binding calc18et, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/8 mile trap speed (mph):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="emph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc18mph, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>                    
            </StackPanel>
            </Border>
            <Border Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="1" BorderBrush="Black" BorderThickness="1" Margin="1">
            <StackPanel>
                <Label Content="Wheel Horse Power Estimator, Enter 1/4 or 1/8 ET" HorizontalAlignment="Center"
                       Margin="5" FontWeight="Bold" FontSize="14"/>
                <Label Content="1/4 Mile ET (sec)" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="twhp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calc14et, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F2}}"/>
                <Label Content="1/8 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="etwhp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calc18et, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F2}}"/>
                <Label Content="Vehicle Weight (lbs)" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="tvw" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calcVehicalWght, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F0}}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="Wheel Horse Power:" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="teet" Width="auto" Margin="0,5,0,5" HorizontalAlignment="Center"
                       Text="{Binding calcWHP, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/4 mile trap speed (mph):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="tqmph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc14mph, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/8 mile trap speed (mph):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="temph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc18mph, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Border>
            <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="1" BorderBrush="Black" BorderThickness="1" Margin="1">
            <StackPanel>
                <Label Content="Wheel Horse Power Estimator, Enter 1/4 or 1/8 Trap Speed" HorizontalAlignment="Center"
                       Margin="5" FontWeight="Bold" FontSize="14"/>
                <Label Content="1/4 Mile TS (mph)" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="ttwhp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calc14mph, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F2}}"/>
                <Label Content="1/8 mile TS (mph):" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="tetwhp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calc18mph, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F2}}"/>
                <Label Content="Vehicle Weight (lbs)" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="ttvw" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calcVehicalWght, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F0}}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="Wheel Horse Power:" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="tteet" Width="auto" Margin="0,5,0,5" HorizontalAlignment="Center"
                       Text="{Binding calcWHP, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/4 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="ttqmph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc14et, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/8 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="ttemph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc18et, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Border>
            <Border Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="1" BorderBrush="Black" BorderThickness="1" Margin="1">
            <StackPanel>
                <Label Content="Weight Estimator" HorizontalAlignment="Center"
                       Margin="5" FontWeight="Bold" FontSize="14"/>
                <Label Content="1/4 Mile TS (mph)" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="wtwhp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calc14mphW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F2}}"/>
                <Label Content="1/8 mile TS (mph):" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="wetwhp" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calc18mphW, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F2}}"/>
                <Label Content="Wheel Horse Power" HorizontalAlignment="Center" FontWeight="Bold"/>
                <TextBox x:Name="wtvw" Width="100" Margin="0,0,0,5" HorizontalContentAlignment="Center"
                     Text="{Binding calcWHP, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Delay=1000, StringFormat={}{0:F0}}"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="Vehicle Weight (lbs):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="wteet" Width="auto" Margin="0,5,0,5" HorizontalAlignment="Center"
                       Text="{Binding calcVehicalWght, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F0}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/4 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="wtqmph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc14et, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,5,0,0">
                    <Label Content="1/8 mile ET (sec):" HorizontalAlignment="Center" FontWeight="Bold"/>
                    <TextBlock x:Name="wtemph" Width="auto" Margin="0,5,0,0" HorizontalAlignment="Center"
                       Text="{Binding calc18et, Mode=OneWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:F2}}" 
                        TextAlignment="Left"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>
