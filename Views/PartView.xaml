<Window x:Class="AutomotiveBuilder.PartView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:command="clr-namespace:MVVMtools.Command;assembly=MVVMtools"
        xmlns:local="clr-namespace:AutomotiveBuilder" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:core="using:Microsoft.Xaml.Interactions.Core"        
        mc:Ignorable="d"
        Title="Parts" Height="800" Width="1200"
        DataContext="{Binding VenderViewModel, Source={StaticResource Locator}}">
    <Grid Margin="2,2,2,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="3*" />
            <RowDefinition Height="3*"/>
            <RowDefinition Height="3*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="7*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>
        <Menu HorizontalAlignment="Stretch" VerticalAlignment="Top" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="1" Height="25">
            <MenuItem Header="File" Width="56">
                <MenuItem Name="Add" Header="Add">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding AddVenderCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="Open" Header="Open">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding OpenVendersCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="Save" Header="Save">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding SaveVendersCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="SaveAs" Header="SaveAs">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding SaveVendersAsCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
            </MenuItem>
        </Menu>
        <StackPanel Grid.Row="1" Grid.Column="0">
        <Label Content="Vender Info" HorizontalAlignment="Left" Height="26" Margin="0,0,0,0"
               VerticalAlignment="Top" Width="358" FontWeight="Bold"/>
        <Border Margin="0,0,0,0" BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" Height="auto" Width="auto">
            <Grid Name="VenderInfo"
                    Height="auto" Margin="0,0,0,0" Width="auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <StackPanel Orientation="Horizontal" Grid.Row="0">
                        <StackPanel Orientation="Vertical">
                            <Label Content="Name" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                      Text="{Binding SelectedVender.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="URL" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                      Text="{Binding SelectedVender.URL, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="1">
                        <StackPanel Orientation="Vertical">
                            <Label Content="Contact Name" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                      Text="{Binding SelectedVender.ContactName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="Phone" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                      Text="{Binding SelectedVender.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="Email" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                      Text="{Binding SelectedVender.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Grid.Row="2">
                        <StackPanel Orientation="Vertical">
                            <Label Content="Address" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                      Text="{Binding SelectedVender.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="City" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                      Text="{Binding SelectedVender.City, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="State" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                      Text="{Binding SelectedVender.State, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                        <StackPanel Orientation="Vertical">
                            <Label Content="Zip" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,10" VerticalAlignment="Top" Width="auto" MinWidth="200"
                                      Text="{Binding SelectedVender.Zip, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>

                    </StackPanel>

                </Grid>
        </Border>
        </StackPanel>
        <Grid Grid.Row="1" Grid.RowSpan="3" Grid.Column="1">
            <DataGrid 
                CanUserAddRows="False" AlternatingRowBackground="LightGray" AlternationCount="2"
                ItemsSource="{Binding MyVenderList, UpdateSourceTrigger=PropertyChanged}"
                SelectedItem="{Binding SelectedVender}"
                ScrollViewer.VerticalScrollBarVisibility="Auto"
                AutoGenerateColumns="False" Margin="5,0,5,5">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Setter Property="IsHitTestVisible" Value="True"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" IsReadOnly="False"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
        <Border Grid.Row="3" BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" Height="auto" Width="auto">
            <Grid/>
        </Border>
    </Grid>
</Window>
