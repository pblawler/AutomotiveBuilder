<Window x:Class="AutomotiveBuilder.Views.MakeModelRepo"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutomotiveBuilder.Views"
        xmlns:command="clr-namespace:MVVMtools.Command;assembly=MVVMtools"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="Make Model Repo" Height="900" Width="1600"
        DataContext="{Binding MakeMod, Source={StaticResource Locator}}">
    <Grid HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="450" />
            <ColumnDefinition Width="1*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="1*" />
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Menu HorizontalAlignment="Stretch" VerticalAlignment="Top" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="1" Height="25">
            <MenuItem Header="File" Width="56">
                <MenuItem Name="Open" Header="Open">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding OpenMakesFileCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="Save" Header="Save">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding SaveMakesCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="SaveAs" Header="SaveAs">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding SaveMakesAsCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="CloseView" Header="Close">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <i:CallMethodAction MethodName="Close"
                           TargetObject="{Binding RelativeSource={RelativeSource
                                                  Mode=FindAncestor,
                                                  AncestorType=Window}}" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
            </MenuItem>
        </Menu>
        <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Left" Height="auto" 
                Margin="30,30,0,0" VerticalAlignment="Stretch" Width="auto" Grid.Row="1" Grid.Column="0">
            <Grid>
                <Label Content="Makes" HorizontalAlignment="Left" Height="25" Margin="0,0,0,0" 
                       VerticalAlignment="Top" Width="193" FontWeight="Bold" FontSize="14"/>
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                <ListView HorizontalAlignment="Stretch" Height="auto" Margin="0,28,0,0" 
                        VerticalAlignment="Stretch" Width="auto" ItemsSource="{Binding Makes}"
                          SelectedItem="{Binding SelectedMake}" SelectionMode="Single">
                    <ListView.View>
                        <GridView AllowsColumnReorder="true" ColumnHeaderToolTip="Make List">
                            <GridViewColumn DisplayMemberBinding="{Binding Name}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Name" Padding="5,0,0,0" HorizontalContentAlignment="Left" MinWidth="150" Name="Name">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <command:EventToCommand Command="{Binding SortMakesNameCommand}" PassEventArgsToCommand="True" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </GridViewColumnHeader>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Country}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Country" Padding="5,0,0,0" HorizontalContentAlignment="Left" MinWidth="150" Name="Country">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <command:EventToCommand Command="{Binding SortMakesCountryCommand}" PassEventArgsToCommand="True" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>                                        
                                    </GridViewColumnHeader>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Phone}" Width="auto">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Phone" Padding="5,0,0,0" HorizontalContentAlignment="Left" MinWidth="150" Name="Phone" />
                                </GridViewColumn.Header>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <command:EventToCommand Command="{Binding SelectMakeCommand}" PassEventArgsToCommand="True" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ListView>
                </ScrollViewer>
            </Grid>
        </Border>
        <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Stretch" Height="auto" 
                Margin="30,30,30,0" VerticalAlignment="Stretch" Width="auto" Grid.Row="1" Grid.Column="1"
                Grid.ColumnSpan="2">
            <ScrollViewer VerticalScrollBarVisibility="Visible" HorizontalScrollBarVisibility="Auto">
            <Grid>
                <Label Content="Name" HorizontalAlignment="Left" Height="25" Margin="30,25,0,0" VerticalAlignment="Top" 
                       Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,51,0,0" TextWrapping="Wrap" 
                        Text="{Binding SelectedMake.Name, Mode=TwoWay}" VerticalAlignment="Top" Width="158"/>
                <Label Content="Address" HorizontalAlignment="Left" Height="25" Margin="30,75,0,0" VerticalAlignment="Top" 
                        Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,101,0,0" TextWrapping="Wrap" 
                        Text="{Binding SelectedMake.Address, Mode=TwoWay}" VerticalAlignment="Top" Width="350"/>
                <Label Content="City" HorizontalAlignment="Left" Height="25" Margin="30,125,0,0" VerticalAlignment="Top" 
                        Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,151,0,0" TextWrapping="Wrap" 
                        Text="{Binding SelectedMake.City, Mode=TwoWay}" VerticalAlignment="Top" Width="238"/>
                <Label Content="State" HorizontalAlignment="Left" Height="25" Margin="30,175,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,201,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedMake.State, Mode=TwoWay}" VerticalAlignment="Top" Width="238"/>
                <Label Content="Zip Code" HorizontalAlignment="Left" Height="25" Margin="30,221,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,247,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedMake.PostalCode, Mode=TwoWay}" VerticalAlignment="Top" Width="238"/>
                <Label Content="Country" HorizontalAlignment="Left" Height="25" Margin="30,267,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,293,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedMake.Country, Mode=TwoWay}" VerticalAlignment="Top" Width="238"/>
                <Label Content="Phone" HorizontalAlignment="Left" Height="25" Margin="30,313,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                    <Button Content="Click to go to URL" HorizontalAlignment="Left" Height="25" Margin="435,22,0,0" VerticalAlignment="Top" 
                        Width="139" HorizontalContentAlignment="Center" FontWeight="Bold">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <command:EventToCommand Command="{Binding BrowseMakeURLCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                    <TextBox HorizontalAlignment="Left" Height="19" Margin="30,339,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedMake.Phone, Mode=TwoWay}" VerticalAlignment="Top" Width="238"/>
                <Label Content="Url" HorizontalAlignment="Left" Height="25" Margin="400,25,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Stretch" Height="19" Margin="400,51,30,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedMake.Url, Mode=TwoWay}" VerticalAlignment="Top" Width="auto"/>
                <Label Content="Discription" HorizontalAlignment="Left" Height="25" Margin="400,71,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Stretch" Height="auto" Margin="400,97,30,30" TextWrapping="Wrap" 
                    Text="{Binding SelectedMake.Description, Mode=TwoWay}" VerticalAlignment="Stretch" Width="auto"/>
                <Button Content="Add Model" HorizontalAlignment="Left" Height="24" Margin="209,46,0,0" VerticalAlignment="Top" Width="171"
                        FontWeight="Bold">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding AddModelCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </Button>
            </Grid>
            </ScrollViewer>
        </Border>

        <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Stretch" Height="auto" 
        Margin="30,30,0,30" VerticalAlignment="Stretch" Width="auto" Grid.Row="2" Grid.Column="0">
            <Grid>
                <Label Content="Models" HorizontalAlignment="Left" Height="25" Margin="0,0,0,0" 
               VerticalAlignment="Top" Width="193" FontWeight="Bold" FontSize="14"/>
                <ListView HorizontalAlignment="Stretch" Height="367" Margin="0,28,0,0" 
                VerticalAlignment="Stretch" Width="auto" ItemsSource="{Binding SelectedMake.Models}"
                  SelectedItem="{Binding SelectedModel}" SelectionMode="Single">
                    <ListView.View>
                        <GridView AllowsColumnReorder="true" ColumnHeaderToolTip="Make List">
                            <GridViewColumn DisplayMemberBinding="{Binding Name}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Name" Padding="5,0,0,0" HorizontalContentAlignment="Left" MinWidth="150" Name="Name2">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <command:EventToCommand Command="{Binding SortMakesNameCommand}" PassEventArgsToCommand="True" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </GridViewColumnHeader>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Trim}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Trim" Padding="5,0,0,0" HorizontalContentAlignment="Left" MinWidth="150" Name="Country2">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <command:EventToCommand Command="{Binding SortMakesCountryCommand}" PassEventArgsToCommand="True" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </GridViewColumnHeader>
                                </GridViewColumn.Header>
                            </GridViewColumn>
                            <GridViewColumn DisplayMemberBinding="{Binding Year}">
                                <GridViewColumn.Header>
                                    <GridViewColumnHeader Content="Year" Padding="5,0,0,0" HorizontalContentAlignment="Left" MinWidth="150" Name="Country3">
                                    </GridViewColumnHeader>
                                </GridViewColumn.Header>
                            </GridViewColumn>                            
                        </GridView>
                    </ListView.View>
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="SelectionChanged">
                            <command:EventToCommand Command="{Binding SelectModelCommand}" PassEventArgsToCommand="True" />
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </ListView>
            </Grid>
        </Border>
        <Border BorderBrush="Black" BorderThickness="1" HorizontalAlignment="Stretch" Height="auto" 
        Margin="30,30,30,30" VerticalAlignment="Stretch" Width="auto" Grid.Row="2" Grid.Column="1"
        Grid.ColumnSpan="2">
            <ScrollViewer VerticalScrollBarVisibility="Visible">
            <Grid>
                <Label Content="Name" HorizontalAlignment="Left" Height="25" Margin="30,25,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,51,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedModel.Name, Mode=TwoWay}" VerticalAlignment="Top" Width="158"/>
                <Label Content="Trim" HorizontalAlignment="Left" Height="25" Margin="30,75,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,101,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedModel.Trim, Mode=TwoWay}" VerticalAlignment="Top" Width="158"/>
                <Label Content="Url" HorizontalAlignment="Left" Height="25" Margin="400,25,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Stretch" Height="19" Margin="400,51,30,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedModel.URL, Mode=TwoWay}" VerticalAlignment="Top" Width="auto"/>
                <Button Content="Click to go to URL" HorizontalAlignment="Left" Height="25" Margin="435,22,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Center" FontWeight="Bold">
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="Click">
                                <command:EventToCommand Command="{Binding BrowseModelURLCommand}"/>
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Button>
                <Label Content="Discription" HorizontalAlignment="Left" Height="25" Margin="400,71,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Stretch" Height="auto" Margin="400,97,30,30" TextWrapping="Wrap" 
                    Text="{Binding SelectedModel.Description, Mode=TwoWay}" VerticalAlignment="Stretch" Width="auto"
                         AcceptsReturn="True"/>
                <Label Content="Year" HorizontalAlignment="Left" Height="25" Margin="30,123,0,0" VerticalAlignment="Top" 
                    Width="139" HorizontalContentAlignment="Left" FontWeight="Bold"/>
                <TextBox HorizontalAlignment="Left" Height="19" Margin="30,149,0,0" TextWrapping="Wrap" 
                    Text="{Binding SelectedModel.Year, Mode=TwoWay}" VerticalAlignment="Top" Width="158"/>
            </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
