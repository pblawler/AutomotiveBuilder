<Window x:Class="AutomotiveBuilder.PartCatagoriesView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:command="clr-namespace:MVVMtools.Command;assembly=MVVMtools"
        xmlns:local="clr-namespace:AutomotiveBuilder" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:core="using:Microsoft.Xaml.Interactions.Core"        
        mc:Ignorable="d"
        Title="Part Catagories" Height="600" Width="1200"
        DataContext="{Binding VenderViewModel, Source={StaticResource Locator}}">
    <Grid Margin="2,2,2,2">
        <Grid.RowDefinitions>
            <RowDefinition Height="25" />
            <RowDefinition Height="6*" />
            <RowDefinition Height="4*"/>
        </Grid.RowDefinitions>
        <Menu HorizontalAlignment="Stretch" VerticalAlignment="Top" Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2" Grid.RowSpan="1" Height="25">
            <MenuItem Header="File" Width="56">
                <MenuItem Name="Add" Header="Add">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding AddCatagoryCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="AddSubCat" Header="Add Subcatagory">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding AddSubCatagoryCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="Open" Header="Open">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding OpenCatagoriesCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="Save" Header="Save">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding SaveCatagoriesCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
                <MenuItem Name="SaveAs" Header="SaveAs">
                    <i:Interaction.Triggers>
                        <i:EventTrigger EventName="Click">
                            <command:EventToCommand Command="{Binding SaveCatagoriesAsCommand}"/>
                        </i:EventTrigger>
                    </i:Interaction.Triggers>
                </MenuItem>
            </MenuItem>
        </Menu>
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Grid.Row="0">
                <Border Margin="0,0,0,5" BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Height="auto" Width="auto">
                    <Grid Name="VenderInfo"
                    Height="auto" Margin="0,0,0,0" Width="auto" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                        <StackPanel>
                            <Label Content="Selected Part Catagory/Subcatagory" HorizontalAlignment="Center" Height="26" Margin="0,0,0,0"
                                VerticalAlignment="Top" Width="358" FontWeight="Bold"/>
                            <Label Content="Part Catagory" HorizontalAlignment="Left" Height="26" Margin="0,0,0,0"
                                VerticalAlignment="Top" Width="358" FontWeight="Bold"/>
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                            <StackPanel Orientation="Vertical">
                                <Label Content="Name" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                      Text="{Binding SelectedPartCatagory.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                            <StackPanel Orientation="Vertical">
                            <Label Content="Description" HorizontalAlignment="Left" Height="23"  Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                            <TextBox HorizontalAlignment="Left" Height="23" Width="800" Margin="10,0,0,10"  MinWidth="200"
                                      Text="{Binding SelectedPartCatagory.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Row="1">
                        <Label Content="SubCatagory" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <StackPanel Orientation="Vertical">
                                <Label Content="Name" HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                                <TextBox HorizontalAlignment="Left" Height="23" Margin="10,0,0,0" VerticalAlignment="Top" Width="202"
                                    Text="{Binding SelectedPartCatagory.SelectedSubcatagory.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                            <StackPanel Orientation="Vertical">
                                <Label Content="Description" HorizontalAlignment="Left" Height="23"  Margin="10,0,0,0" VerticalAlignment="Top" Width="139" HorizontalContentAlignment="Left"/>
                                <TextBox HorizontalAlignment="Left" Height="23" Width="800" Margin="10,0,0,10"  MinWidth="200"
                                    Text="{Binding SelectedPartCatagory.SelectedSubcatagory.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>
                    </Grid>
            </Border>
        </StackPanel>
            <Border Margin="0,0,0,5" BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Height="auto" Width="auto" Grid.Row="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Label Grid.Row="0" Content="Subcatagories" FontWeight="Bold"/>
                    <DataGrid Grid.Row="1"
                 CanUserAddRows="False" AlternatingRowBackground="LightGray" AlternationCount="2"
                 ItemsSource="{Binding SelectedPartCatagory.SubCategories, UpdateSourceTrigger=PropertyChanged}"
                 SelectedItem="{Binding SelectedPartCatagory.SelectedSubcatagory}"
                 ScrollViewer.VerticalScrollBarVisibility="Auto" Margin ="5"
                 AutoGenerateColumns="False">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow">
                                <Setter Property="IsHitTestVisible" Value="True"/>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="350" IsReadOnly="False"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="False"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>
        </Grid>
        <Border Margin="0,0,0,5" BorderBrush="Black" BorderThickness="2" HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch" Height="auto" Width="auto" Grid.Row="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Label Grid.Row="0" Content="Catagories" FontWeight="Bold"/>
                <DataGrid Grid.Row="1"
                        CanUserAddRows="False" AlternatingRowBackground="LightGray" AlternationCount="2"
                        ItemsSource="{Binding PartCatagories, UpdateSourceTrigger=PropertyChanged}"
                        SelectedItem="{Binding SelectedPartCatagory}"
                        ScrollViewer.VerticalScrollBarVisibility="Auto"
                        AutoGenerateColumns="False" Margin="5,0,5,5">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Setter Property="IsHitTestVisible" Value="True"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="350" IsReadOnly="False"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*" IsReadOnly="False"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>
